APP_NAME='PCPB'
APP_ENV=local                          # local | production
APP_KEY=
APP_DEBUG=true #false se em produção
APP_URL=http://localhost:8015          # local: http://localhost:8000 | docker: http://localhost:8015
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# API de autenticação externa
API_TOKEN=
API_LOGIN_URL=

WWWUSER=1000
WWWGROUP=1000

# -------------------------------------------------------
# LOGS
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# -------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=postgres
DB_PASSWORD=

# -------------------------------------------------------
# CACHE / SESSÃO / FILA
# -------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost  #atenção ao app_url
SESSION_COOKIE=pcpb_session
SESSION_SECURE_COOKIE=false   #true se em produção
SESSION_SAME_SITE=lax
FORCE_HTTPS=false

# -------------------------------------------------------
# STORAGE — MinIO (S3-compatible)
# -------------------------------------------------------
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://minio:9000         # local: http://localhost:9000 | docker: http://minio:9000
AWS_URL=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

AWS_BUCKET=veiculos                    # Veículos apreendidos
AWS_BUCKET_FOTOS=funcionais            # Fotos dos servidores

# -------------------------------------------------------
# E-MAIL
# -------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit                      # docker: mailpit | local: localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@pc.pb.gov.br"
MAIL_FROM_NAME="${APP_NAME}"

CONTATO_INSTITUTIONAL_EMAIL=

# -------------------------------------------------------
# VITE
# -------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
